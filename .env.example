# ── Gemini (Google AI) ─────────────────────────────────────────────────────
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ── Google Cloud ───────────────────────────────────────────────────────────
# Path to your Google Cloud service-account JSON file
# The service account must have these APIs enabled:
#   - Cloud Speech-to-Text API
#   - Cloud Text-to-Speech API
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/google-credentials.json

# ── Twilio ─────────────────────────────────────────────────────────────────
# Found at: console.twilio.com → Account Info (top of dashboard)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Only ONE number below — pick from: console.twilio.com → Phone Numbers → Active Numbers
TWILIO_PHONE_NUMBER=+1234567890

# ── Server ─────────────────────────────────────────────────────────────────
# Public HTTPS base URL (use ngrok during development)
# Example: https://abc123.ngrok-free.app
BASE_URL=https://your-server.ngrok-free.dev

# ── Escalation ─────────────────────────────────────────────────────────────
# E.164 phone number to transfer escalated calls to
# Leave empty to just hang up on escalation during development
ESCALATION_NUMBER=+94XXXXXXXXX

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5433/cmc_agent

# ── Redis (session store — shared across all workers) ──────────────────────
# Local dev: redis runs in Docker on port 6379
# Production (Docker Compose): use redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# ── Server mode ────────────────────────────────────────────────────────────
# Set to "production" to enable Gunicorn multi-worker mode
ENVIRONMENT=development

# ── Gunicorn workers ───────────────────────────────────────────────────────
# Rule of thumb: (2 × CPU cores) + 1
# 4 works well on a 1-2 core VM; increase for bigger machines
WEB_CONCURRENCY=4
